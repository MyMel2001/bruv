# bruv configuration template
# Copy this file to ~/.config/bruv/bruv.env and customize

# ---- User Identity ----
# Set these to enable auto-register on first private action.
# If BRUV_USER_NAME and BRUV_USER_PASSWORD are set, bruv will
# automatically attempt to register (or login if already registered)
# when you perform a private action without being authenticated.
BRUV_USER_NAME=
BRUV_USER_EMAIL=
BRUV_USER_PASSWORD=

# ---- Auto-Register ----
# When true, bruv will automatically register/login using the credentials
# above the first time you try a private action (sharing, private repos, etc.)
# without being authenticated. Set to false to disable.
BRUV_AUTO_REGISTER=true

# ---- API Server ----
BRUV_API_URL=https://api.bruv.sh
BRUV_API_PORT=2658

# ---- AI Integration ----
# Configure an OpenAI-compatible endpoint for automated merge
# and safety scanning of files before commit.
BRUV_AI_ENDPOINT=
BRUV_AI_API_KEY=
BRUV_AI_MODEL=gpt-4o

# ---- Security ----
# .env files are ALWAYS blocked regardless of these settings.
BRUV_DANGER_FLAG_DEFAULT=false
BRUV_BLOCK_ENV_FILES=true
BRUV_BLOCKED_PATTERNS=.env,.env.*,*.pem,*.key,id_rsa,id_ed25519,credentials.json,service-account.json,secrets.yml,secrets.yaml,.npmrc,.pypirc,.netrc

# ---- Merge Behavior ----
# union = conflict-free merge (default)
# manual = always ask the user
# ai = let AI decide
BRUV_MERGE_STRATEGY=union

# What to do when conflicts are found
# ask = prompt the user
# custom = interactive per-file choice
# automated = let AI decide
BRUV_CONFLICT_STRATEGY=ask

# ---- Privacy ----
# Whether new repos/snapshots/PRs default to private
BRUV_DEFAULT_PRIVATE=false
